rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Private per-user data (sessions/configs/solvedSolutions/etc.)
    match /users/{uid} {
      allow read, write: if isOwner(uid);
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Public profile + public stats (sanitized)
    match /publicUsers/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // Phase 2: leaderboards (write via Cloud Functions only)
    match /leaderboards/{period}/entries/{uid} {
      allow read: if true;
      allow write: if false;
    }
  }
}

